<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd" >
<mapper namespace="com.skyeye.exam.examsurveydirectory.dao.ExamSurveyDirectoryDao">
    <select id="queryExamLists" parameterType="java.util.Map"  resultType="com.skyeye.exam.examsurveydirectory.entity.ExamSurveyDirectory">
        SELECT * FROM exam_survey_directory a
        <where>
            <if test="holderKey != null and holderKey != ''">
                AND a.school_id = #{holderKey}
            </if>
            <if test="holderId != null and holderId != ''">
                AND a.faculty_id = #{holderId}
            </if>
            <if test="objectKey!= null and objectKey != ''">
                AND a.major_id = #{objectKey}
            </if>
            <if test="objectId != null and objectId != ''">
                AND a.subject_id = #{objectId}
            </if>
        </where>
    </select>
</mapper>